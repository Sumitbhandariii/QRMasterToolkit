{
  "expo": {
    "name": "QR Master Toolkit",
    "slug": "qrmaster-toolkit",
    "version": "1.0.0",
    "owner": "techeditz8",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "qrmastertoolkit",
    "userInterfaceStyle": "light",
    "newArchEnabled": false,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.qrmaster.toolkit"
    },
    "android": {
      "package": "com.qrmaster.toolkit",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.READ_MEDIA_IMAGES",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE",
        "android.permission.FLASHLIGHT",
        "android.permission.INTERNET",
        "android.permission.ACCESS_NETWORK_STATE",
        "android.permission.RECORD_AUDIO",
        "android.permission.ACCESS_MEDIA_LOCATION"
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      [
        "expo-camera",
        {
          "cameraPermission": "QR Master needs camera access to scan QR codes and barcodes."
        }
      ],
      [
        "expo-media-library",
        {
          "photosPermission": "QR Master needs access to save generated QR codes.",
          "savePhotosPermission": "QR Master needs permission to save QR codes to your gallery.",
          "isAccessMediaLocationEnabled": true
        }
      ],
      [
        "react-native-google-mobile-ads",
        {
          "androidAppId": "ca-app-pub-8212461864193378~4599440732",
          "iosAppId": "ca-app-pub-8212461864193378~4599440732"
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "5c735bd2-34f0-44b6-9015-92dc33311ac5"
      }
    }
  }
}
